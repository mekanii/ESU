.DS_Store

# Ignore backup files
*.bak

# Ignore DWL files
*.dwl

# Ignore DWL2 files
*.dwl2

# Ignore temporary Excel files
hardware/~$*.xlsx
~$*.xlsx

# Ignore dot-tilde files (temporary/backup files like .~Request PO 20250807.xlsx)
.~*

# Ignore dot-dollar backup files (like .$Firmware-ESU-CTL-1-Button.drawio.bkp)
.$*

# PlatformIO specific files
.pio/
.vscode/
.platformio/
lib_deps/
*.pioenvs/
*.pio/

# PlatformIO build artifacts (but allow other .bin files)
.pio/build/**/*.bin
*.elf
*.hex
*.map
*.d
*.o
*.a
*.dSYM/
*.lst

# Build output
/build/
*.out
*.exe

# IDE specific files
*.swp
*.swo
*.user
*.sublime-workspace
*.sublime-project

# MacOS specific files
.DS_Store

# Windows specific files
Thumbs.db
ehthumbs.db

# Logs
*.log

# Temporary files
*.tmp
*.temp

# KIcad specific files
**/.history/
hardware/**/~*.kicad_sch.lck
hardware/**/~*.kicad_pcb.lck
hardware/**/~*.kicad_pro.lck
hardware/**/*-backups/
